# Configuration Environnement NetflixLight Backend

# Environment
NODE_ENV=development

# Server
PORT=3000

# Base de données SQLite
DB_PATH=./data/netflixlight.db

# TMDB API (The Movie Database)
# Obtenir votre clé sur https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BEARER_TOKEN=your_tmdb_bearer_token_here

# JWT Configuration
# IMPORTANT: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_generated_jwt_secret_here_128_chars
JWT_EXPIRES_IN=24h

# Session Configuration
# IMPORTANT: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_generated_session_secret_here_128_chars

# CORS
CORS_ORIGIN=http://localhost:5500

# Security
BCRYPT_ROUNDS=10
